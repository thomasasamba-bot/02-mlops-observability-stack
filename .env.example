# =============================================================================
# .env.example
# 02-observability-ml-alerting — ML Pipeline Observability Stack
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored. Never commit real credentials.
# =============================================================================

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=credit-scoring
MODEL_NAME=credit-scoring-model
MODEL_STAGE=Staging

# ── Inference server (app/serving/app.py) ─────────────────────────────────────
SERVICE_NAME=ml-inference-server
SERVICE_VERSION=1.0.0
MAX_BATCH_SIZE=500
LOG_LEVEL=INFO

# ── Prediction thresholds ─────────────────────────────────────────────────────
DECISION_THRESHOLD=0.40      # below 0.5 = recall-focused for credit risk
LOW_CONF_LOW=0.35            # low-confidence band lower bound
LOW_CONF_HIGH=0.55           # low-confidence band upper bound
PREDICTION_BUFFER_SIZE=2000  # rolling prediction buffer size
MODEL_RELOAD_INTERVAL=300    # seconds between model version checks

# ── Drift detector ────────────────────────────────────────────────────────────
DRIFT_WINDOW=300             # predictions sampled per drift check
DRIFT_INTERVAL=120           # seconds between drift check cycles
PSI_WARN_THRESHOLD=0.10      # PSI warning threshold
PSI_ALERT_THRESHOLD=0.25     # PSI alert threshold
KS_ALPHA=0.05                # KS-test significance level
MIN_WINDOW_SIZE=50           # minimum predictions before drift check runs

# ── Metrics exporter (app/exporter/metrics_exporter.py) ──────────────────────
EXPORTER_POLL_INTERVAL=60    # seconds between MLflow/dataset scrape cycles
INFERENCE_BASE_URL=http://localhost:8006

# ── Data paths ────────────────────────────────────────────────────────────────
SCHEMA_PATH=data/processed/feature_schema.json
BASELINE_CSV=data/raw/credit_baseline.csv
DRIFTED_CSV=data/raw/credit_drifted.csv

# ── AWS (for Terraform / CloudWatch integration) ──────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=default           # AWS CLI profile to use
# AWS_ACCESS_KEY_ID=           # set if not using AWS_PROFILE
# AWS_SECRET_ACCESS_KEY=       # set if not using AWS_PROFILE

# ── Alerting ──────────────────────────────────────────────────────────────────
ALERT_EMAIL=                  # email for SNS CloudWatch alerts (Terraform var)
ALERTMANAGER_URL=http://localhost:9093

# ── Ports (local dev) ─────────────────────────────────────────────────────────
MLFLOW_PORT=5000
INFERENCE_PORT=8006
EXPORTER_PORT=8007
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ALERTMANAGER_PORT=9093
